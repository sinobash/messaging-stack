# RabbitMQ Settings
RABBITMQ_VERSION=rabbitmq:4.3-management-alpine
HOST_AMQP_PORT_RABBITMQ=5672
HOST_PORT_RABBITMQ=15672
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=tiger