# Runtime Settings
PROJECT_PATH=.
LOCAL_LISTEN_ADDR=127.0.0.1
NEW_UID=1000
NEW_GID=1000

# Redis Settings
REDIS_VERSION=redis:7.2-alpine
HOST_PORT_REDIS=6379
